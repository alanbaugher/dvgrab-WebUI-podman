###############################################################################

###############################################################################
# Python
###############################################################################

__pycache__/
*.py[cod]
*$py.class

###############################################################################
# Virtual environments
###############################################################################

venv/
.venv/

###############################################################################
# Local configuration
###############################################################################

.env
.env.*

###############################################################################
# Local project state
###############################################################################

state/

###############################################################################
# Local archives and backups
###############################################################################

archive/

###############################################################################
# SQLite (future development)
###############################################################################

*.db
*.sqlite
*.sqlite3

###############################################################################
# Logs
###############################################################################

*.log

###############################################################################
# Editor files
###############################################################################

*~
*.swp
*.swo
.vscode/
.idea/

###############################################################################
# Operating system files
###############################################################################

.DS_Store
Thumbs.db

###############################################################################
